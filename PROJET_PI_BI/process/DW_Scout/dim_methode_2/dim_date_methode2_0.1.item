    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties shellMaximized="true"/>
      <varTables sizeState="INTERMEDIATE" name="Var">
        <mapperTableEntries name="maDate" expression="TalendDate.addDate(TalendDate.parseDate(&quot;yyyy-MM-dd&quot;, &quot;1960-01-01&quot;), row1.id, &quot;dd&quot;) " type="id_Date"/>
      </varTables>
      <outputTables sizeState="INTERMEDIATE" name="out1">
        <mapperTableEntries name="full_date" expression="Var.maDate " type="id_Date" nullable="true"/>
        <mapperTableEntries name="date_id" expression="Integer.parseInt(TalendDate.formatDate(&quot;yyyyMMdd&quot;, Var.maDate)) " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="jour_nom" expression="TalendDate.formatDate(&quot;EEEE&quot;, Var.maDate) " type="id_String" nullable="true"/>
        <mapperTableEntries name="mois_nom" expression="TalendDate.formatDate(&quot;MMMM&quot;, Var.maDate)" type="id_String" nullable="true"/>
        <mapperTableEntries name="annee" expression="TalendDate.getPartOfDate(&quot;YEAR&quot;, Var.maDate) " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="trimestre" expression="(TalendDate.getPartOfDate(&quot;MONTH&quot;, Var.maDate) / 3) + 1 " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="saison" expression="(TalendDate.getPartOfDate(&quot;MONTH&quot;, Var.maDate) + 1 >= 9) ? &#xD;&#xA;(TalendDate.getPartOfDate(&quot;YEAR&quot;, Var.maDate) + &quot;_&quot; + (TalendDate.getPartOfDate(&quot;YEAR&quot;, Var.maDate) + 1)) : &#xD;&#xA;((TalendDate.getPartOfDate(&quot;YEAR&quot;, Var.maDate) - 1) + &quot;-&quot; + TalendDate.getPartOfDate(&quot;YEAR&quot;, Var.maDate)) " type="id_String" nullable="true"/>
      </outputTables>
      <inputTables sizeState="INTERMEDIATE" name="row1" matchingMode="UNIQUE_MATCH" lookupMode="LOAD_ONCE">
        <mapperTableEntries name="id" type="id_Integer" nullable="true"/>
      </inputTables>
    </nodeData>
  </node>
